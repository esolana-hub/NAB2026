              </div>
              <div style={{ fontSize: "52px", fontWeight: "900", color: "#c8a84b", lineHeight: 1 }}>
                {pct}%
              </div>
              <div style={{ color: "#8a9ab0", marginTop: "4px", fontSize: "14px" }}>
                {score} / {examQuestions.length} correctas
              </div>
              <div style={{
                display: "inline-block", marginTop: "12px",
                background: "rgba(200,168,75,0.15)", border: "1px solid rgba(200,168,75,0.4)",
                color: "#c8a84b", padding: "6px 16px", borderRadius: "20px", fontSize: "13px", fontWeight: "600"
              }}>
                {grade}
              </div>
            </div>

            <div style={{ display: "grid", gap: "14px" }}>
              {examQuestions.map(q => {
                const userAns = examAnswers[q.id];
                const correct = userAns === q.correct;
                return (
                  <div key={q.id} style={{
                    background: correct ? "rgba(40,180,80,0.07)" : "rgba(220,60,60,0.07)",
                    border: `1px solid ${correct ? "rgba(40,180,80,0.3)" : "rgba(220,60,60,0.3)"}`,
                    borderRadius: "10px", padding: "16px 18px"
                  }}>
                    <div style={{ display: "flex", justifyContent: "space-between", marginBottom: "8px" }}>
                      <div style={{ fontSize: "12px", fontFamily: "monospace", color: "#8a9ab0" }}>P{q.id} · {q.section}</div>
                      <div style={{ fontSize: "16px" }}>{correct ? "✅" : "❌"}</div>
                    </div>
                    <div style={{ fontWeight: "600", color: "#e8e0d0", fontSize: "13px", marginBottom: "8px", lineHeight: "1.5" }}>
                      {q.question}
                    </div>
                    {!correct && (
                      <div style={{ fontSize: "12px", color: "#e8a0a0", marginBottom: "6px" }}>
                        Tu respuesta: {q.options[userAns]}
                      </div>
                    )}
                    <div style={{ fontSize: "12px", color: "#70c090", marginBottom: "8px" }}>
                      ✓ {q.options[q.correct]}
                    </div>
                    <div style={{ fontSize: "12px", color: "#7a8a9a", lineHeight: "1.5", borderTop: "1px solid rgba(255,255,255,0.07)", paddingTop: "8px" }}>
                      {q.explanation}
                    </div>
                  </div>
                );
              })}
            </div>

            <div style={{ display: "flex", gap: "12px", marginTop: "24px" }}>
              <button onClick={() => { setSubmitted(false); setExamAnswers({}); setCurrentQ(0); }}
                style={{ flex: 1, background: "#c8a84b", border: "none", color: "#0a0f1e", padding: "14px", borderRadius: "8px", cursor: "pointer", fontWeight: "700", fontSize: "14px", letterSpacing: "1px" }}>
                REPETIR EXAMEN
              </button>
              <button onClick={() => { setMode("menu"); setSubmitted(false); setExamAnswers({}); setCurrentQ(0); }}
                style={{ flex: 1, background: "rgba(255,255,255,0.06)", border: "1px solid rgba(255,255,255,0.15)", color: "#e8e0d0", padding: "14px", borderRadius: "8px", cursor: "pointer", fontWeight: "700", fontSize: "14px" }}>
                IR A ESTUDIO
              </button>
            </div>
          </div>
        )}
      </div>
    </div>
  );
}
